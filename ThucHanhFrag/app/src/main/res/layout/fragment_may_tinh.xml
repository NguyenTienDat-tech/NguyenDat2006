<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".presentation.ui.MayTinh">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".presentation.ui.MainActivity">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/board"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_255sdp"
            android:background="@color/white"
            app:layout_constraintTop_toTopOf="parent"
            tools:layout_editor_absoluteX="0dp">

            <ImageView
                android:id="@+id/muiten"
                android:layout_width="@dimen/_20sdp"
                android:layout_height="@dimen/_20sdp"
                android:layout_marginTop="@dimen/_35sdp"
                android:layout_marginStart="@dimen/_24sdp"
                android:src="@drawable/muiten"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Calculator"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:textSize="@dimen/_15ssp"
                android:gravity="center"
                app:layout_constraintTop_toTopOf="@id/muiten"
                app:layout_constraintBottom_toBottomOf="@id/muiten"/>

            <TextView
                android:id="@+id/ketqua"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/_15sdp"
                android:gravity="end"
                android:text="@string/_0"
                android:textColor="#352D2A"
                android:textSize="@dimen/_60sdp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/_12sdp"
            app:layout_constraintTop_toBottomOf="@id/board"
            app:layout_constraintBottom_toBottomOf="parent">


            <TextView
                android:id="@+id/C"
                android:layout_width="@dimen/_70sdp"
                android:layout_height="@dimen/_70sdp"
                android:background="@drawable/bottomcalculator"
                android:textColor="#ED920E"
                android:text="C"
                android:textSize="@dimen/_40sdp"
                android:gravity="center"
                app:layout_constraintStart_toStartOf="parent"/>

            <TextView
                android:id="@+id/dongmongoac"
                android:layout_width="@dimen/_70sdp"
                android:layout_height="@dimen/_70sdp"
                android:background="@drawable/bottomcalculator"
                android:textColor="@color/black"
                android:text="( )"
                android:textSize="@dimen/_40sdp"
                android:gravity="center"
                android:layout_marginStart="@dimen/_5sdp"
                app:layout_constraintStart_toEndOf="@id/C" />

            <ImageView
                android:id="@+id/xoa"
                android:layout_width="@dimen/_70sdp"
                android:layout_height="@dimen/_70sdp"
                android:src="@drawable/xoa"
                android:textColor="#223EDA"
                android:icon="@drawable/discover"
                android:textSize="@dimen/_40sdp"
                android:gravity="center"
                android:layout_marginStart="@dimen/_5sdp"
                app:layout_constraintStart_toEndOf="@id/dongmongoac" />

            <ImageView
                android:id="@+id/chia"
                android:layout_width="@dimen/_70sdp"
                android:layout_height="@dimen/_70sdp"
                android:src="@drawable/chia"
                android:textSize="@dimen/_40sdp"
                android:gravity="center"
                android:layout_marginStart="@dimen/_5sdp"
                app:layout_constraintStart_toEndOf="@id/xoa" />

            <TextView
                android:id="@+id/bay"
                android:layout_width="@dimen/_70sdp"
                android:layout_height="@dimen/_70sdp"
                android:background="@drawable/bottomcalculator"
                android:textColor="@color/black"
                android:text="7"
                android:textSize="@dimen/_40sdp"
                android:gravity="center"
                android:layout_marginStart="@dimen/_5sdp"
                app:layout_constraintTop_toBottomOf="@+id/C"/>

            <TextView
                android:id="@+id/tam"
                android:layout_width="@dimen/_70sdp"
                android:layout_height="@dimen/_70sdp"
                android:background="@drawable/bottomcalculator"
                android:textColor="@color/black"
                android:text="8"
                android:textSize="@dimen/_40sdp"
                android:gravity="center"
                android:layout_marginStart="@dimen/_5sdp"
                app:layout_constraintStart_toEndOf="@id/bay"
                app:layout_constraintTop_toBottomOf="@id/dongmongoac"/>

            <TextView
                android:id="@+id/chin"
                android:layout_width="@dimen/_70sdp"
                android:layout_height="@dimen/_70sdp"
                android:background="@drawable/bottomcalculator"
                android:textColor="@color/black"
                android:text="9"
                android:textSize="@dimen/_40sdp"
                android:gravity="center"
                android:layout_marginStart="@dimen/_5sdp"
                app:layout_constraintStart_toEndOf="@id/tam"
                app:layout_constraintTop_toBottomOf="@id/xoa"/>

            <TextView
                android:id="@+id/nhan"
                android:layout_width="@dimen/_70sdp"
                android:layout_height="@dimen/_70sdp"
                android:background="@drawable/bottomcalculator"
                android:textColor="#223EDA"
                android:text="x"
                android:textSize="@dimen/_40sdp"
                android:gravity="center"
                android:layout_marginStart="@dimen/_5sdp"
                app:layout_constraintStart_toEndOf="@id/chin"
                app:layout_constraintTop_toBottomOf="@id/chia"/>

            <TextView
                android:id="@+id/bon"
                android:layout_width="@dimen/_70sdp"
                android:layout_height="@dimen/_70sdp"
                android:background="@drawable/bottomcalculator"
                android:textColor="@color/black"
                android:text="4"
                android:textSize="@dimen/_40sdp"
                android:gravity="center"
                android:layout_marginStart="@dimen/_5sdp"
                app:layout_constraintTop_toBottomOf="@id/bay"/>

            <TextView
                android:id="@+id/nam"
                android:layout_width="@dimen/_70sdp"
                android:layout_height="@dimen/_70sdp"
                android:background="@drawable/bottomcalculator"
                android:textColor="@color/black"
                android:text="5"
                android:textSize="@dimen/_40sdp"
                android:gravity="center"
                android:layout_marginStart="@dimen/_5sdp"
                app:layout_constraintStart_toEndOf="@id/bon"
                app:layout_constraintTop_toBottomOf="@id/tam"/>

            <TextView
                android:id="@+id/sau"
                android:layout_width="@dimen/_70sdp"
                android:layout_height="@dimen/_70sdp"
                android:background="@drawable/bottomcalculator"
                android:textColor="@color/black"
                android:text="6"
                android:textSize="@dimen/_40sdp"
                android:gravity="center"
                android:layout_marginStart="@dimen/_5sdp"
                app:layout_constraintStart_toEndOf="@id/nam"
                app:layout_constraintTop_toBottomOf="@id/chin"/>

            <TextView
                android:id="@+id/tru"
                android:layout_width="@dimen/_70sdp"
                android:layout_height="@dimen/_70sdp"
                android:background="@drawable/bottomcalculator"
                android:textColor="#223EDA"
                android:text="-"
                android:textSize="@dimen/_40sdp"
                android:gravity="center"
                android:layout_marginStart="@dimen/_5sdp"
                app:layout_constraintStart_toEndOf="@id/sau"
                app:layout_constraintTop_toBottomOf="@id/nhan"/>

            <TextView
                android:id="@+id/mot"
                android:layout_width="@dimen/_70sdp"
                android:layout_height="@dimen/_70sdp"
                android:background="@drawable/bottomcalculator"
                android:textColor="@color/black"
                android:text="1"
                android:textSize="@dimen/_40sdp"
                android:gravity="center"
                android:layout_marginStart="@dimen/_5sdp"
                app:layout_constraintTop_toBottomOf="@id/bon"/>

            <TextView
                android:id="@+id/hai"
                android:layout_width="@dimen/_70sdp"
                android:layout_height="@dimen/_70sdp"
                android:background="@drawable/bottomcalculator"
                android:textColor="@color/black"
                android:text="2"
                android:textSize="@dimen/_40sdp"
                android:gravity="center"
                android:layout_marginStart="@dimen/_5sdp"
                app:layout_constraintStart_toEndOf="@id/mot"
                app:layout_constraintTop_toBottomOf="@id/nam"/>

            <TextView
                android:id="@+id/ba"
                android:layout_width="@dimen/_70sdp"
                android:layout_height="@dimen/_70sdp"
                android:background="@drawable/bottomcalculator"
                android:textColor="@color/black"
                android:text="3"
                android:textSize="@dimen/_40sdp"
                android:gravity="center"
                android:layout_marginStart="@dimen/_5sdp"
                app:layout_constraintStart_toEndOf="@id/hai"
                app:layout_constraintTop_toBottomOf="@id/sau"/>

            <TextView
                android:id="@+id/cong"
                android:layout_width="@dimen/_70sdp"
                android:layout_height="@dimen/_70sdp"
                android:background="@drawable/bottomcalculator"
                android:textColor="#223EDA"
                android:text="+"
                android:textSize="@dimen/_40sdp"
                android:gravity="center"
                android:layout_marginStart="@dimen/_5sdp"
                app:layout_constraintStart_toEndOf="@id/ba"
                app:layout_constraintTop_toBottomOf="@id/tru"/>

            <TextView
                android:id="@+id/chiadu"
                android:layout_width="@dimen/_70sdp"
                android:layout_height="@dimen/_70sdp"
                android:background="@drawable/bottomcalculator"
                android:textColor="@color/black"
                android:text="%"
                android:textSize="@dimen/_40sdp"
                android:gravity="center"
                android:layout_marginStart="@dimen/_5sdp"
                app:layout_constraintTop_toBottomOf="@id/mot"/>

            <TextView
                android:id="@+id/khong"
                android:layout_width="@dimen/_70sdp"
                android:layout_height="@dimen/_70sdp"
                android:background="@drawable/bottomcalculator"
                android:textColor="@color/black"
                android:text="0"
                android:textSize="@dimen/_40sdp"
                android:gravity="center"
                android:layout_marginStart="@dimen/_5sdp"
                app:layout_constraintStart_toEndOf="@id/chiadu"
                app:layout_constraintTop_toBottomOf="@id/hai"/>

            <TextView
                android:id="@+id/cham"
                android:layout_width="@dimen/_70sdp"
                android:layout_height="@dimen/_70sdp"
                android:background="@drawable/bottomcalculator"
                android:textColor="@color/black"
                android:text="."
                android:textSize="@dimen/_40sdp"
                android:gravity="center"
                android:layout_marginStart="@dimen/_5sdp"
                app:layout_constraintStart_toEndOf="@id/khong"
                app:layout_constraintTop_toBottomOf="@id/ba"/>

            <TextView
                android:id="@+id/bang"
                android:layout_width="@dimen/_70sdp"
                android:layout_height="@dimen/_70sdp"
                android:background="@drawable/bottomblue"
                android:text="="
                android:textSize="@dimen/_40sdp"
                android:textColor="@color/white"
                android:gravity="center"
                android:layout_marginStart="@dimen/_5sdp"
                app:layout_constraintStart_toEndOf="@id/cham"
                app:layout_constraintTop_toBottomOf="@id/cong"/>

            <TextView
                android:layout_width="@dimen/_15sdp"
                android:layout_height="@dimen/_350sdp"
                android:background="@drawable/bottomblue"
                android:text="s"
                android:gravity="center"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="@dimen/_15ssp"

                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                tools:layout_editor_absoluteX="0dp" />


        </androidx.constraintlayout.widget.ConstraintLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>