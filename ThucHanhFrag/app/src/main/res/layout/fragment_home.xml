<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#77D3D3D3"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".presentation.ui.HomeFragment">

   <androidx.constraintlayout.widget.ConstraintLayout
      android:layout_width="match_parent"
      android:layout_height="match_parent">

      <androidx.constraintlayout.widget.ConstraintLayout
          android:id="@+id/groundblue"
         android:layout_width="match_parent"
         android:layout_height="@dimen/_140sdp"
         android:background="@drawable/groundblue"
         app:layout_constraintTop_toTopOf="parent">

      </androidx.constraintlayout.widget.ConstraintLayout>


      <LinearLayout
          android:id="@+id/bottom"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:background="@drawable/bottom"
          android:layout_marginHorizontal="@dimen/_30sdp"
          android:paddingVertical="@dimen/_15sdp"
          android:layout_marginTop="@dimen/_120sdp"
          android:orientation="horizontal"
          app:layout_constraintTop_toTopOf="parent"
          app:layout_constraintStart_toStartOf="parent"
          app:layout_constraintEnd_toEndOf="parent">

          <ImageView
              android:id="@+id/giaodich"
              android:layout_width="@dimen/_40sdp"
              android:layout_height="@dimen/_40sdp"
              android:src="@drawable/giaodich"
              android:layout_marginStart="@dimen/_10sdp"/>

          <ImageView
              android:id="@+id/danhsach"
              android:layout_width="@dimen/_40sdp"
              android:layout_height="@dimen/_40sdp"
              android:src="@drawable/danhsach"
              android:layout_marginStart="@dimen/_20sdp" />

          <ImageView
              android:id="@+id/phiendich"
              android:layout_width="@dimen/_40sdp"
              android:layout_height="@dimen/_40sdp"
              android:src="@drawable/phiendich"
              android:layout_marginStart="@dimen/_20sdp" />

          <ImageView
              android:id="@+id/caidat"
              android:layout_width="@dimen/_40sdp"
              android:layout_height="@dimen/_40sdp"
              android:src="@drawable/caidat"
              android:layout_marginStart="@dimen/_20sdp"/>
      </LinearLayout>


       <androidx.viewpager2.widget.ViewPager2
           android:id="@+id/viewPaper"
           android:layout_width="match_parent"
           android:layout_height="0dp"
           app:layout_constraintTop_toBottomOf="@+id/bottom"
           app:layout_constraintBottom_toBottomOf="parent"/>

   </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>